---
const GITHUB_USERNAME = 'moizifty';
---

<header>
	<nav>
		<a href="/" class="brand">Pinned Projects</a>
		<div class="nav-right">
			<a
				class="cactus-link"
				href={`https://github.com/${GITHUB_USERNAME}`}
				target="_blank"
				rel="noopener noreferrer"
			>
				GitHub
			</a>
			<button id="theme-toggle" type="button" aria-label="Toggle color theme">
				<svg
					id="sun-icon"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<circle cx="12" cy="12" r="4"></circle>
					<path
						d="M12 3v1M12 20v1M4.2 4.2l.7.7M19.1 19.1l.7.7M3 12h1M20 12h1M4.2 19.8l.7-.7M19.1 4.9l.7-.7"
					></path>
				</svg>
				<svg
					id="moon-icon"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="M20 14.5A8.5 8.5 0 1 1 9.5 4a7 7 0 0 0 10.5 10.5Z"></path>
				</svg>
			</button>
		</div>
	</nav>
</header>

<script is:inline>
	(function () {
		function setUp() {
			const button = document.getElementById('theme-toggle');
			if (!button) return;

			button.addEventListener('click', () => {
				const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
				const next = isDark ? 'light' : 'dark';
				document.documentElement.setAttribute('data-theme', next);
				localStorage.setItem('theme', next);
			});
		}

		setUp();
		document.addEventListener('astro:after-swap', setUp);
	})();
</script>

<style>
	header {
		background: var(--color-bg);
		border-bottom: 1px dashed var(--color-border);
		position: sticky;
		top: 0;
		z-index: 10;
	}

	nav {
		max-width: 1200px;
		margin: 0 auto;
		padding: 1rem 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	nav a {
		text-decoration: none;
		color: var(--color-text);
	}

	.brand {
		font-weight: 700;
		font-size: 1.1rem;
		color: var(--color-accent-2);
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 1.25rem;
	}

	.nav-right a {
		color: var(--color-muted);
		font-size: 0.95rem;
	}

	#theme-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		padding: 0;
		border: none;
		background: none;
		color: var(--color-muted);
		cursor: pointer;
		border-radius: 999px;
	}

	#theme-toggle:hover {
		color: var(--color-accent);
		background: var(--color-surface);
	}

	#theme-toggle svg {
		width: 1.25rem;
		height: 1.25rem;
	}

	#sun-icon {
		display: none;
	}

	:global(html[data-theme='dark']) #sun-icon {
		display: block;
	}

	:global(html[data-theme='dark']) #moon-icon {
		display: none;
	}
</style>
