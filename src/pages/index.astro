---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { fetchPinnedRepos } from '../lib/github';

const repos = await fetchPinnedRepos();

const docsEntries: CollectionEntry<'docs'>[] = await getCollection('docs');
const projectsWithDocs = new Set(docsEntries.map((entry) => entry.id.split('/')[0]));
---

<Layout>
	<main>
		<h1>Pinned Projects</h1>
		<div class="grid">
			{
				repos.map((repo) => {
					const hasDocs = projectsWithDocs.has(repo.name);
					const href = hasDocs ? `/projects/${repo.name}/` : repo.html_url;
					return (
						<a
							class:list={['tile', { 'has-docs': hasDocs }]}
							href={href}
							target={hasDocs ? undefined : '_blank'}
							rel={hasDocs ? undefined : 'noopener noreferrer'}
							transition:name={`project-${repo.name}`}
						>
							<div class="tile-header">
								<h2>{repo.name}</h2>
								{hasDocs && <span class="docs-badge">📄 Docs</span>}
							</div>
							{repo.description && <p>{repo.description}</p>}
							<div class="meta">
								{repo.language && <span class="language">{repo.language}</span>}
								<span class="stars">★ {repo.stargazers_count.toLocaleString()}</span>
							</div>
						</a>
					);
				})
			}
		</div>
	</main>
</Layout>

<style>
	main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 3rem 1.5rem 5rem;
	}

	h1 {
		text-align: center;
		font-size: 2.25rem;
		font-weight: 700;
		color: var(--color-accent-2);
		margin-bottom: 2.5rem;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 300px));
		justify-content: center;
		gap: 1.5rem;
	}

	.tile {
		display: flex;
		flex-direction: column;
		padding: 1.5rem;
		border-radius: 14px;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		box-shadow: 0 4px 14px hsl(var(--shadow-color) / 10%);
		text-decoration: none;
		color: inherit;
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease,
			border-color 0.2s ease;
	}

	.tile:hover {
		transform: translateY(-4px);
		border-color: var(--color-muted);
		box-shadow: 0 10px 24px hsl(var(--shadow-color) / 18%);
	}

	.tile.has-docs {
		border-color: var(--color-accent);
	}

	.tile.has-docs:hover {
		box-shadow:
			0 0 0 1px var(--color-accent),
			0 10px 24px hsl(var(--shadow-color) / 18%);
	}

	.tile-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		margin-bottom: 0.5rem;
	}

	.tile h2 {
		margin: 0;
		font-size: 1.1rem;
		font-weight: 600;
		color: var(--color-accent-2);
		word-break: break-word;
	}

	.docs-badge {
		flex-shrink: 0;
		font-size: 0.72rem;
		font-weight: 600;
		color: var(--color-accent);
		border: 1px solid var(--color-accent);
		padding: 0.2rem 0.55rem;
		border-radius: 999px;
	}

	.tile p {
		margin: 0 0 1rem;
		font-size: 0.9rem;
		line-height: 1.4;
		color: var(--color-muted);
		flex-grow: 1;
	}

	.meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		font-size: 0.85rem;
		color: var(--color-muted);
	}

	.language {
		padding: 0.15rem 0.6rem;
		border-radius: 999px;
		border: 1px dashed var(--color-border);
	}

	.stars {
		font-weight: 600;
		color: var(--color-accent);
	}
</style>
