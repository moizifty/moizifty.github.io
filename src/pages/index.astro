---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { fetchPinnedRepos } from '../lib/github';

const repos = await fetchPinnedRepos();

const docsEntries: CollectionEntry<'docs'>[] = await getCollection('docs');
const projectsWithDocs = new Set(docsEntries.map((entry) => entry.id.split('/')[0]));
---

<Layout>
	<main>
		<h1>Pinned Projects</h1>
		<div class="grid">
			{
				repos.map((repo) => {
					const hasDocs = projectsWithDocs.has(repo.name);
					const href = hasDocs ? `/projects/${repo.name}/` : repo.html_url;
					return (
						<a
							class="tile"
							href={href}
							target={hasDocs ? undefined : '_blank'}
							rel={hasDocs ? undefined : 'noopener noreferrer'}
							transition:name={`project-${repo.name}`}
						>
							<h2>{repo.name}</h2>
							{repo.description && <p>{repo.description}</p>}
							<div class="meta">
								{repo.language && <span class="language">{repo.language}</span>}
								<span class="stars">★ {repo.stargazers_count.toLocaleString()}</span>
							</div>
						</a>
					);
				})
			}
		</div>
	</main>
</Layout>

<style>
	main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 3rem 1.5rem 5rem;
		font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
	}

	h1 {
		text-align: center;
		font-size: 2rem;
		color: #111827;
		margin-bottom: 2.5rem;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 300px));
		justify-content: center;
		gap: 1.5rem;
	}

	.tile {
		display: flex;
		flex-direction: column;
		padding: 1.5rem;
		border-radius: 14px;
		background: #ffffff;
		box-shadow: 0 4px 14px rgba(0, 0, 0, 0.1);
		text-decoration: none;
		color: inherit;
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease;
	}

	.tile:hover {
		transform: translateY(-4px);
		box-shadow: 0 10px 24px rgba(0, 0, 0, 0.16);
	}

	.tile h2 {
		margin: 0 0 0.5rem;
		font-size: 1.1rem;
		color: #111827;
		word-break: break-word;
	}

	.tile p {
		margin: 0 0 1rem;
		font-size: 0.9rem;
		line-height: 1.4;
		color: #4b5563;
		flex-grow: 1;
	}

	.meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		font-size: 0.85rem;
		color: #6b7280;
	}

	.language {
		padding: 0.15rem 0.6rem;
		border-radius: 999px;
		background: #f3f4f6;
	}

	.stars {
		font-weight: 600;
		color: #b45309;
	}
</style>
